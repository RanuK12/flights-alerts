# Flight Price Bot - Environment Variables
# Copy this file as .env and configure your values

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Price Thresholds
PRICE_THRESHOLD=300

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Optional: Custom Skyscanner Settings
# SKYSCANNER_THRESHOLD=500
# SKYSCANNER_CURRENCY=EUR

# Optional: Custom Routes
# You can modify routes in index.js according to your needs

# Instructions:
# 1. Get your TELEGRAM_BOT_TOKEN from @BotFather on Telegram
# 2. Run 'node get-chat-id.js' to get your TELEGRAM_CHAT_ID
# 3. Configure your PostgreSQL database
# 4. Adjust PRICE_THRESHOLD according to your needs 